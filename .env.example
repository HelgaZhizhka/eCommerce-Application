# Copy to .env and fill in. NEVER commit .env.
# Values come from Merchant Center → Settings → Developer settings
# (use a "Mobile & single-page application" template client — minimal scopes).

# ── Browser (bundled by Vite) — no secrets here ─────────────────────────────
VITE_PROJECT_KEY_CLIENT=your-project-key
# Region API host, e.g. https://api.europe-west1.gcp.commercetools.com
VITE_API_URL_CLIENT=https://api.europe-west1.gcp.commercetools.com

# ── Server-side only (Netlify Functions auth BFF) ───────────────────────────
# Locally `netlify dev` injects these into functions; in production set them
# in Netlify UI (Site settings → Environment variables).
CTP_PROJECT_KEY=your-project-key
CTP_CLIENT_ID=your-client-id
CTP_CLIENT_SECRET=your-client-secret
CTP_AUTH_URL=https://auth.europe-west1.gcp.commercetools.com
# Space-separated scope string as shown in the client details
CTP_SCOPES=
