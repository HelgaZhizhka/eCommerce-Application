# Commercetools API client (Merchant Center → Settings → Developer settings)
# Copy to .env and fill in. NEVER commit .env.
# NOTE: until phase 2 (BFF) these values are embedded in the browser bundle —
# use a client created from the "Mobile & single-page application" template
# (minimal scopes), never an admin client.

VITE_PROJECT_KEY_CLIENT=your-project-key
VITE_CLIENT_ID_CLIENT=your-client-id
VITE_CLIENT_SECRET_CLIENT=your-client-secret
# Region host pair — take from the API client details page:
VITE_API_URL_CLIENT=https://api.europe-west1.gcp.commercetools.com
VITE_AUTH_URL_CLIENT=https://auth.europe-west1.gcp.commercetools.com
# Space-separated scope string as shown in the client details, e.g.
# "view_published_products:your-project-key manage_my_orders:your-project-key ..."
VITE_SCOPES_CLIENT=
