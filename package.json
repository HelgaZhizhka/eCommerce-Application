{
  "name": "ecommerce-app",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@commercetools/platform-sdk": "^8.27.0",
    "@commercetools/ts-client": "^4.10.0",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-slider": "^1.4.0",
    "@tanstack/react-query": "^5.101.0",
    "framer-motion": "^12.0.0",
    "lucide-react": "^1.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.79.0",
    "react-router-dom": "^6.14.2",
    "swiper": "^12.2.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.19.21",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "clsx": "^2.1.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^8.0.3",
    "jsdom": "^29.1.1",
    "lint-staged": "^13.2.3",
    "msw": "^2.14.6",
    "netlify-cli": "^26.1.0",
    "prettier": "^3.8.4",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^7.3.5",
    "vitest": "^4.1.8"
  },
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build && printf '\\n# SPA fallback (build-only, see public/_redirects)\\n/*  /index.html  200\\n' >> build/_redirects",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p netlify",
    "prettier": "prettier --write .",
    "eslint:fix": "eslint . --fix",
    "eslint": "eslint .",
    "prepare": "husky install",
    "postinstall": "chmod +x .husky/*",
    "ignorecase": "git config core.ignorecase false"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --cache --fix",
      "prettier --write"
    ]
  },
  "overrides": {
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/core": "^2.8.0",
    "micromatch": "^4.0.8",
    "yaml": "^2.8.3",
    "undici": "^7.28.0",
    "http-proxy-middleware": "^3.0.7"
  }
}
